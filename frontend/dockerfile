# ===== ETAP 1: Budowanie =====
FROM node:20-alpine AS build

WORKDIR /app

# Kopiowanie plików zależności
COPY package.json package-lock.json* ./

# Instalacja zależności
RUN npm install

# Kopiowanie kodu źródłowego
COPY . .

# Budowanie aplikacji produkcyjnej
RUN npm run build -- --configuration=production

# ===== ETAP 2: Serwowanie =====
FROM nginx:alpine

# Usunięcie domyślnej konfiguracji nginx
RUN rm /etc/nginx/conf.d/default.conf

# Kopiowanie własnej konfiguracji
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Kopiowanie zbudowanej aplikacji
COPY --from=build /app/dist/currency-frontend/browser /usr/share/nginx/html

# Expose port
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
